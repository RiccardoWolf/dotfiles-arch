      "$CONFIG_HOME/google-chrome" \
      "$CONFIG_HOME/chromium" \
      -maxdepth 2 \
      -type f \
      -name Preferences \
      \( -path "*/Default/Preferences" -o -path "*/Profile */Preferences" \) \
