#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd -P)"
REPO_ROOT="${DOTFILES_ARCH_REPO:-$(cd -- "$SCRIPT_DIR/../../.." && pwd -P)}"

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
APP_NAME="dotfiles-arch"
STATE_DIR="$STATE_HOME/$APP_NAME"
STATE_THEME_DIR="$STATE_DIR/themes"
CURRENT_DIR="$STATE_DIR/current"
CURRENT_FILE="$STATE_DIR/theme"
CONFIG_APP_DIR="$CONFIG_HOME/$APP_NAME"
CONFIG_THEME_DIR="$CONFIG_APP_DIR/themes"
CHROME_CDP_PORT="${THEME_SWITCH_CHROME_CDP_PORT:-9222}"
CHROME_CDP_URL="${THEME_SWITCH_CHROME_CDP_URL:-http://127.0.0.1:$CHROME_CDP_PORT}"

SOURCE_THEME_ROOT="${THEME_SWITCH_THEME_ROOT:-}"
if [[ -z "$SOURCE_THEME_ROOT" ]]; then
  if [[ -d "$STATE_THEME_DIR/dark" && -d "$STATE_THEME_DIR/light" ]]; then
    SOURCE_THEME_ROOT="$STATE_THEME_DIR"
  elif [[ -d "$REPO_ROOT/home/.config/$APP_NAME/themes" ]]; then
    SOURCE_THEME_ROOT="$REPO_ROOT/home/.config/$APP_NAME/themes"
  else
    SOURCE_THEME_ROOT="$STATE_THEME_DIR"
  fi
fi
RUNTIME_THEME_ROOT="$STATE_THEME_DIR"

usage() {
  cat <<EOF
Usage:
  theme-switch apply <dark|light>
  theme-switch prepare [dark|light]
  theme-switch toggle
  theme-switch current
  theme-switch help

Environment:
  THEME_SWITCH_CHROME_CDP_PORT   Chrome DevTools port for live repainting; default: 9222
  THEME_SWITCH_CHROME_CDP_URL    Full Chrome DevTools URL override, for example http://127.0.0.1:9222
  THEME_SWITCH_CHROME_LIVE=0     Disable Chrome DevTools live repainting
  THEME_SWITCH_CODEX_LIGHT       Codex TUI theme for light mode; default: raccoon-readable
  THEME_SWITCH_CODEX_DARK        Codex TUI theme for dark mode; default: onedark
EOF
}

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'theme-switch: %s\n' "$*" >&2
}

SUPPORTED_ADAPTERS=(vscode chromium chrome-live zsh codex spicetify)

all_supported_adapters() {
  printf '%s\n' "${SUPPORTED_ADAPTERS[*]}"
}

adapter_in_list() {
  local list="$1"
  local adapter="$2"

  [[ " $list " == *" $adapter "* ]]
}


backup_file() {
  local path="$1"
  local stamp rel backup_path

  [[ -f "$path" ]] || return 0
  stamp="${THEME_SWITCH_BACKUP_STAMP:-$(date +%Y%m%d%H%M%S)}"
  THEME_SWITCH_BACKUP_STAMP="$stamp"

  rel="${path#$HOME/}"
  if [[ "$rel" == "$path" ]]; then
    rel="${path#/}"
  fi

  backup_path="$STATE_DIR/backups/$stamp/$rel"
  mkdir -p -- "$(dirname -- "$backup_path")"
  if [[ ! -e "$backup_path" ]]; then
    cp -p -- "$path" "$backup_path"
  fi
}

backup_path_for_replace() {
  local path="$1"
  local stamp rel backup_path

  [[ -e "$path" || -L "$path" ]] || return 0
  stamp="${THEME_SWITCH_BACKUP_STAMP:-$(date +%Y%m%d%H%M%S)}"
  THEME_SWITCH_BACKUP_STAMP="$stamp"

  rel="${path#$HOME/}"
  if [[ "$rel" == "$path" ]]; then
    rel="${path#/}"
  fi

  backup_path="$STATE_DIR/backups/$stamp/$rel"
  mkdir -p -- "$(dirname -- "$backup_path")"
  if [[ ! -e "$backup_path" && ! -L "$backup_path" ]]; then
    mv -- "$path" "$backup_path"
  fi
}

die() {
  warn "$*"
  exit 1
}

ensure_mode() {
  local mode="$1"
  [[ "$mode" == "dark" || "$mode" == "light" ]] || die "expected mode 'dark' or 'light', got: $mode"
}

source_theme_dir() {
  local mode="$1"
  local path="$SOURCE_THEME_ROOT/$mode"

  [[ -d "$path" ]] || die "missing theme directory: $path"
  printf '%s\n' "$path"
}

theme_file() {
  local mode="$1"
  local name="$2"
  local path="$RUNTIME_THEME_ROOT/$mode/$name"

  [[ -f "$path" ]] || die "missing theme asset: $path"
  printf '%s\n' "$path"
}

replace_managed_link() {
  local source="$1"
  local target="$2"
  local current_source

  if [[ -L "$target" ]]; then
    current_source="$(readlink -f -- "$target" 2>/dev/null || true)"
    if [[ "$current_source" == "$(readlink -f -- "$source")" ]]; then
      return 0
    fi
    backup_path_for_replace "$target"
  elif [[ -e "$target" ]]; then
    backup_path_for_replace "$target"
  fi

  ln -s -- "$source" "$target"
}

sync_theme_mode_assets() {
  local mode="$1"
  local source_dir target_dir source_real target_real

  source_dir="$(source_theme_dir "$mode")"
  target_dir="$RUNTIME_THEME_ROOT/$mode"
  source_real="$(readlink -f -- "$source_dir")"
  target_real="$(readlink -f -- "$target_dir" 2>/dev/null || true)"

  if [[ -n "$target_real" && "$source_real" == "$target_real" ]]; then
    return 0
  fi

  if [[ -L "$target_dir" ]]; then
    backup_path_for_replace "$target_dir"
  elif [[ -e "$target_dir" && ! -d "$target_dir" ]]; then
    backup_path_for_replace "$target_dir"
  fi

  mkdir -p -- "$target_dir"
  cp -a -- "$source_dir"/. "$target_dir"/
}

prepare_config_theme_links() {
  local mode="${1:-dark}"

  ensure_mode "$mode"
  source_theme_dir dark >/dev/null
  source_theme_dir light >/dev/null

  if [[ -L "$CONFIG_APP_DIR" ]]; then
    die "$CONFIG_APP_DIR is a symlink; runtime theme state must be user-owned, not stowed into the repo"
  fi

  if [[ -e "$CONFIG_APP_DIR" && ! -d "$CONFIG_APP_DIR" ]]; then
    die "$CONFIG_APP_DIR exists but is not a directory"
  fi

  mkdir -p -- "$STATE_DIR" "$STATE_THEME_DIR" "$CURRENT_DIR" "$CONFIG_THEME_DIR"
  sync_theme_mode_assets dark
  sync_theme_mode_assets light
  replace_managed_link "$STATE_THEME_DIR/dark" "$CONFIG_THEME_DIR/dark"
  replace_managed_link "$STATE_THEME_DIR/light" "$CONFIG_THEME_DIR/light"
  replace_managed_link "$CURRENT_DIR" "$CONFIG_THEME_DIR/current"
}

resolve_edit_target() {
  local path="$1"
  local resolved

  if [[ -L "$path" ]]; then
    resolved="$(readlink -f -- "$path" 2>/dev/null || true)"
    [[ -n "$resolved" ]] || die "refusing to update symlink with missing target: $path"
    printf '%s\n' "$resolved"
    return 0
  fi

  printf '%s\n' "$path"
}

target_mode() {
  local path="$1"
  local fallback="$2"

  if [[ -e "$path" ]]; then
    stat -c '%a' -- "$path"
  else
    printf '%s\n' "$fallback"
  fi
}

install_generated_file() {
  local tmp="$1"
  local path="$2"
  local fallback_mode="$3"
  local target mode

  target="$(resolve_edit_target "$path")"
  mode="$(target_mode "$target" "$fallback_mode")"
  mkdir -p -- "$(dirname -- "$target")"
  backup_file "$target"
  install -m "$mode" -- "$tmp" "$target"
}

install_source_file() {
  local source="$1"
  local path="$2"
  local fallback_mode="$3"
  local target mode

  target="$(resolve_edit_target "$path")"
  mode="$(target_mode "$target" "$fallback_mode")"
  mkdir -p -- "$(dirname -- "$target")"
  backup_file "$target"
  install -m "$mode" -- "$source" "$target"
}

link_current() {
  local mode="$1"
  local source_name="$2"
  local current_name="$3"
  local source_path

  source_path="$(theme_file "$mode" "$source_name")"
  mkdir -p -- "$CURRENT_DIR"
  ln -sfn -- "$source_path" "$CURRENT_DIR/$current_name"
  log "$current_name -> $source_path"
}

run_optional() {
  if "$@"; then
    return 0
  fi

  warn "optional command failed: $(printf '%q ' "$@")"
  return 0
}

set_gsettings_if_writable() {
  local schema="$1"
  local key="$2"
  local value="$3"

  command -v gsettings &>/dev/null || return 0
  if gsettings writable "$schema" "$key" 2>/dev/null | grep -qx true; then
    run_optional gsettings set "$schema" "$key" "$value"
  fi
}

set_xfconf() {
  local channel="$1"
  local property="$2"
  local type="$3"
  local value="$4"

  command -v xfconf-query &>/dev/null || return 0
  run_optional xfconf-query -c "$channel" -p "$property" --create -t "$type" -s "$value"
}

update_gtk_settings_ini() {
  local path="$1"
  local gtk_theme="$2"
  local prefer_dark="$3"
  local prefer_dark_int=0
  local tmp target

  command -v python3 &>/dev/null || return 0
  [[ "$prefer_dark" == true ]] && prefer_dark_int=1

  target="$(resolve_edit_target "$path")"
  mkdir -p -- "$(dirname -- "$target")"
  tmp="$(mktemp)"
  if python3 - "$target" "$gtk_theme" "$prefer_dark_int" > "$tmp" <<'PY'
from configparser import ConfigParser
from pathlib import Path
import sys

path = Path(sys.argv[1])
gtk_theme = sys.argv[2]
prefer_dark = sys.argv[3]

config = ConfigParser()
config.optionxform = str
if path.exists():
    config.read(path)
if not config.has_section("Settings"):
    config.add_section("Settings")

config.set("Settings", "gtk-theme-name", gtk_theme)
config.set("Settings", "gtk-application-prefer-dark-theme", prefer_dark)
config.write(sys.stdout, space_around_delimiters=False)
PY
  then
    install_generated_file "$tmp" "$path" 0644
  else
    warn "failed to update GTK settings file: $path"
  fi
  rm -f -- "$tmp"
}

apply_xdg_gtk() {
  local mode="$1"
  local color_scheme gtk_theme prefer_dark

  if [[ "$mode" == "dark" ]]; then
    color_scheme="prefer-dark"
    gtk_theme="${THEME_SWITCH_GTK_DARK:-Adwaita}"
    prefer_dark=true
  else
    color_scheme="prefer-light"
    gtk_theme="${THEME_SWITCH_GTK_LIGHT:-Adwaita}"
    prefer_dark=false
  fi

  set_gsettings_if_writable org.gnome.desktop.interface color-scheme "$color_scheme"
  set_gsettings_if_writable org.gnome.desktop.interface gtk-theme "$gtk_theme"
  set_gsettings_if_writable org.gnome.desktop.interface gtk-application-prefer-dark-theme "$prefer_dark"

  set_xfconf xsettings /Net/ThemeName string "$gtk_theme"

  update_gtk_settings_ini "$CONFIG_HOME/gtk-3.0/settings.ini" "$gtk_theme" "$prefer_dark"
  update_gtk_settings_ini "$CONFIG_HOME/gtk-4.0/settings.ini" "$gtk_theme" "$prefer_dark"
}

reload_waybar() {
  local style="$CONFIG_HOME/waybar/style.css"

  # Waybar reload_style_on_change observes stylesheet mtime changes. Touching the
  # entry stylesheet refreshes colors without reloading the Waybar process.
  if [[ -f "$style" ]]; then
    touch -- "$style"
    return 0
  fi

  command -v systemctl &>/dev/null &&
    systemctl --user --quiet is-active waybar.service &>/dev/null &&
    run_optional systemctl --user kill -s SIGUSR2 --kill-who=main waybar.service &&
    return 0

  command -v pkill &>/dev/null &&
    pkill -0 waybar &>/dev/null &&
    run_optional pkill -SIGUSR2 waybar

  return 0
}

reload_kitty() {
  local colors="$CURRENT_DIR/kitty.conf"
  local config="$CONFIG_HOME/kitty/kitty.conf"
  local runtime="${XDG_RUNTIME_DIR:-}"
  local pid socket
  local reloaded=0
  local missing_socket=0
  local failed=0
  local -a command_prefix=()
  local -a pids=()

  command -v kitten &>/dev/null || return 0
  command -v pgrep &>/dev/null || return 0
  [[ -n "$runtime" ]] || return 0
  if command -v timeout &>/dev/null; then
    command_prefix=(timeout 2s)
  fi

  mapfile -t pids < <(pgrep -x kitty 2>/dev/null || true)
  ((${#pids[@]} > 0)) || return 0

  for pid in "${pids[@]}"; do
    socket="$runtime/kitty-theme-switch-$pid"
    if [[ ! -S "$socket" ]]; then
      missing_socket=1
      continue
    fi

    if "${command_prefix[@]}" kitten @ --to "unix:$socket" load-config "$config" &&
      "${command_prefix[@]}" kitten @ --to "unix:$socket" set-colors --all --configured "$colors"; then
      reloaded=1
    else
      failed=1
    fi
  done

  if ((failed)); then
    warn "kitty reload failed for one or more managed sockets"
  fi
  if ((missing_socket && ! reloaded)); then
    warn "kitty is running without the managed theme reload socket; restart kitty once so future theme switches can reload it live"
  elif ((missing_socket)); then
    warn "some kitty windows are running without the managed theme reload socket; restart those kitty windows once so future theme switches can reload them live"
  fi
}

reload_dunst() {
  local config="$CURRENT_DIR/dunst.conf"

  install_dunst_startup_config
  command -v dunstctl &>/dev/null || return 0
  run_optional dunstctl reload "$config"
}

install_dunst_startup_config() {
  local dunst_dir="$CONFIG_HOME/dunst"
  local target="$dunst_dir/dunstrc"
  local source="$CONFIG_THEME_DIR/current/dunst.conf"
  local target_link

  if [[ -L "$dunst_dir" ]]; then
    log "dunst: replacing stowed config directory with runtime-owned config link"
    backup_path_for_replace "$dunst_dir"
  elif [[ -e "$dunst_dir" && ! -d "$dunst_dir" ]]; then
    die "$dunst_dir exists but is not a directory"
  fi

  mkdir -p -- "$dunst_dir"

  if [[ -L "$target" ]]; then
    target_link="$(readlink -- "$target" 2>/dev/null || true)"
    if [[ "$target_link" == "$source" ]]; then
      return 0
    fi
    backup_path_for_replace "$target"
  elif [[ -e "$target" ]]; then
    backup_path_for_replace "$target"
  fi

  ln -s -- "$source" "$target"
  log "dunst: startup config -> $source"
}

update_zsh_theme() {
  local mode="$1"
  local zshrc="$HOME/.zshrc"
  local theme tmp target

  [[ -e "$zshrc" || -L "$zshrc" ]] || return 0
  if [[ "$mode" == "dark" ]]; then
    theme="${THEME_SWITCH_ZSH_DARK:-robbyrussell}"
  else
    theme="${THEME_SWITCH_ZSH_LIGHT:-robbyrussell}"
  fi

  target="$(resolve_edit_target "$zshrc")"
  tmp="$(mktemp "$STATE_DIR/zshrc.XXXXXX")"
  awk -v theme="$theme" '
    BEGIN { done = 0 }
    /^ZSH_THEME=/ {
      print "ZSH_THEME=\"" theme "\""
      done = 1
      next
    }
    { print }
    END {
      if (!done) {
        print "ZSH_THEME=\"" theme "\""
      }
    }
  ' "$target" > "$tmp"
  if cmp -s -- "$tmp" "$target"; then
    rm -f -- "$tmp"
  else
    install_generated_file "$tmp" "$zshrc" 0644
    rm -f -- "$tmp"
    log "zsh: set ZSH_THEME to $theme"
  fi
}

update_codex_theme() {
  local mode="$1"
  local codex_home="${CODEX_HOME:-$HOME/.codex}"
  local config="$codex_home/config.toml"
  local light_theme="${THEME_SWITCH_CODEX_LIGHT:-raccoon-readable}"
  local dark_theme="${THEME_SWITCH_CODEX_DARK:-onedark}"
  local active_theme asset theme_target tmp config_target

  command -v python3 &>/dev/null || return 0

  if [[ "$mode" == "dark" ]]; then
    active_theme="$dark_theme"
  else
    active_theme="$light_theme"
  fi

  mkdir -p -- "$codex_home"

  if [[ -n "$active_theme" ]]; then
    asset="$RUNTIME_THEME_ROOT/$mode/codex/$active_theme.tmTheme"
    theme_target="$codex_home/themes/$active_theme.tmTheme"
    if [[ -f "$asset" ]]; then
      python3 - "$asset" <<'PY'
import plistlib
import sys
from pathlib import Path

with Path(sys.argv[1]).open("rb") as handle:
    plistlib.load(handle)
PY
      mkdir -p -- "$codex_home/themes"
      install_source_file "$asset" "$theme_target" 0644
      log "codex: installed theme asset $active_theme"
    elif [[ "$active_theme" == "raccoon-readable" || "$active_theme" == "onedark" ]]; then
      die "missing Codex theme asset: $asset"
    fi
  fi

  config_target="$(resolve_edit_target "$config")"
  tmp="$(mktemp "$STATE_DIR/codex-config.XXXXXX")"
  if python3 - "$config_target" "$active_theme" > "$tmp" <<'PY'
import json
import re
import sys
import tomllib
from pathlib import Path

path = Path(sys.argv[1])
theme = sys.argv[2]
text = path.read_text() if path.exists() else ""

if text.strip():
    tomllib.loads(text)

lines = text.splitlines(keepends=True)
out = []
table_re = re.compile(r"^\s*\[([^\]]+)\]\s*(?:#.*)?$")
theme_re = re.compile(r"^\s*theme\s*=")
in_tui = False
seen_tui = False
theme_written = False

def theme_line():
    return f"theme = {json.dumps(theme)}\n"

for line in lines:
    table_match = table_re.match(line)
    if table_match:
        if in_tui and theme and not theme_written:
            out.append(theme_line())
            theme_written = True
        table_name = table_match.group(1).strip()
        in_tui = table_name == "tui"
        seen_tui = seen_tui or in_tui

    if in_tui and theme_re.match(line):
        if theme and not theme_written:
            out.append(theme_line())
            theme_written = True
        continue

    out.append(line)

if in_tui and theme and not theme_written:
    out.append(theme_line())
    theme_written = True

if not seen_tui and theme:
    if out and not out[-1].endswith("\n"):
        out[-1] += "\n"
    if out and "".join(out).strip():
        out.append("\n")
    out.extend(["[tui]\n", theme_line()])

new_text = "".join(out)
if new_text.strip():
    tomllib.loads(new_text)
sys.stdout.write(new_text)
PY
  then
    if [[ ! -f "$config_target" && ! -s "$tmp" ]]; then
      rm -f -- "$tmp"
    elif [[ ! -f "$config_target" ]] || ! cmp -s -- "$tmp" "$config_target"; then
      install_generated_file "$tmp" "$config" 0600
      rm -f -- "$tmp"
      if [[ -n "$active_theme" ]]; then
        log "codex: set TUI theme to $active_theme"
      else
        log "codex: removed TUI theme override"
      fi
    else
      rm -f -- "$tmp"
    fi
  else
    rm -f -- "$tmp"
    warn "failed to update Codex config: $config"
  fi

  reload_codex_theme "$active_theme" "$codex_home"
}

reload_codex_theme() {
  local active_theme="$1"
  local codex_home="$2"
  local control_sock="${CODEX_APP_SERVER_CONTROL_SOCKET:-$codex_home/app-server-control/app-server-control.sock}"
  local message
  local -a command_prefix=()

  if command -v timeout &>/dev/null; then
    command_prefix=(timeout 2s)
  fi

  if [[ -S "$control_sock" ]] && command -v codex &>/dev/null; then
    message='{"jsonrpc":"2.0","id":1,"method":"config/batchWrite","params":{"edits":[],"reloadUserConfig":true}}'
    if printf '%s\n' "$message" | "${command_prefix[@]}" codex app-server proxy --sock "$control_sock" >/dev/null 2>&1; then
      log "codex: requested live config reload for ${active_theme:-default}"
      return 0
    fi
    warn "codex: app-server reload request failed; running TUI may keep its current theme"
    return 0
  fi

  if command -v pgrep &>/dev/null && command -v kill &>/dev/null; then
    while IFS= read -r pid; do
      kill -WINCH "$pid" 2>/dev/null || true
    done < <(pgrep -u "$USER" -f '/codex/codex( |$)' 2>/dev/null || true)
  fi

  warn "codex: current terminal TUI cannot hotswap themes because no app-server control socket is exposed; new Codex sessions will use ${active_theme:-the default theme}"
}

detect_vscode_builtin_theme() {
  local mode="$1"
  local fallback app_root package_json
  local -a app_roots=(
    "/opt/visual-studio-code/resources/app"
    "/usr/lib/code"
    "/usr/lib/code-oss"
  )

  if [[ "$mode" == "dark" ]]; then
    fallback="Dark 2026"
  else
    fallback="Light 2026"
  fi

  command -v python3 &>/dev/null || {
    printf '%s\n' "$fallback"
    return 0
  }

  for app_root in "${app_roots[@]}"; do
    package_json="$app_root/extensions/theme-defaults/package.json"
    [[ -f "$package_json" ]] || continue
    python3 - "$package_json" "$mode" "$fallback" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
mode = sys.argv[2]
fallback = sys.argv[3]

themes = json.loads(path.read_text()).get("contributes", {}).get("themes", [])
wanted_ui = "vs-dark" if mode == "dark" else "vs"
preferred = ["Dark 2026", "Dark Modern", "Dark+"] if mode == "dark" else ["Light 2026", "Light Modern", "Light+"]
ids = [theme.get("id") or theme.get("label") for theme in themes if theme.get("uiTheme") == wanted_ui]

for candidate in preferred:
    if candidate in ids:
        print(candidate)
        raise SystemExit(0)
print(ids[0] if ids else fallback)
PY
    return 0
  done

  printf '%s\n' "$fallback"
}

update_vscode_theme() {
  local mode="$1"
  local dark_theme="${THEME_SWITCH_VSCODE_DARK:-$(detect_vscode_builtin_theme dark)}"
  local light_theme="${THEME_SWITCH_VSCODE_LIGHT:-$(detect_vscode_builtin_theme light)}"
  local active_theme settings tmp changed=0 target
  local -a settings_paths=(
    "$CONFIG_HOME/Code/User/settings.json"
    "$CONFIG_HOME/Code - OSS/User/settings.json"
    "$CONFIG_HOME/VSCodium/User/settings.json"
  )

  command -v python3 &>/dev/null || return 0
  if [[ "$mode" == "dark" ]]; then
    active_theme="$dark_theme"
  else
    active_theme="$light_theme"
  fi

  while IFS= read -r settings; do
    settings_paths+=("$settings")
  done < <(
    find \
      "$CONFIG_HOME/Code/User/profiles" \
      "$CONFIG_HOME/Code - OSS/User/profiles" \
      "$CONFIG_HOME/VSCodium/User/profiles" \
      -mindepth 2 \
      -maxdepth 2 \
      -type f \
      -name settings.json \
      2>/dev/null | sort
  )

  for settings in "${settings_paths[@]}"; do
    [[ -e "$settings" || -L "$settings" || -d "$(dirname -- "$settings")" ]] || continue
    target="$(resolve_edit_target "$settings")"
    mkdir -p -- "$(dirname -- "$target")"
    tmp="$(mktemp "$STATE_DIR/vscode-settings.XXXXXX")"
    if python3 - "$target" "$active_theme" "$dark_theme" "$light_theme" > "$tmp" <<'PY'
import json
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
active_theme = sys.argv[2]
dark_theme = sys.argv[3]
light_theme = sys.argv[4]

text = path.read_text() if path.exists() else "{\n}\n"
updates = {
    "window.autoDetectColorScheme": False,
    "workbench.preferredDarkColorTheme": dark_theme,
    "workbench.preferredLightColorTheme": light_theme,
    "workbench.colorTheme": active_theme,
}

def setting_line(key, value, indent="  "):
    return f"{indent}{json.dumps(key)}: {json.dumps(value)}"

for key, value in list(updates.items()):
    pattern = re.compile(
        r'^(\s*)' + re.escape(json.dumps(key)) + r'\s*:\s*.*?(,?)\s*(?://.*)?$',
        re.MULTILINE,
    )

    def replace(match):
        return setting_line(key, value, match.group(1)) + match.group(2)

    text, count = pattern.subn(replace, text)
    if count:
        updates.pop(key)

if updates:
    close_index = text.rfind("}")
    if close_index == -1:
        raise SystemExit(f"{path}: expected a JSON object ending in '}}'")
    before = text[:close_index].rstrip()
    after = text[close_index:]
    prefix = "" if before.endswith("{") else ","
    block = "\n" + ",\n".join(setting_line(k, v) for k, v in updates.items()) + "\n"
    text = before + prefix + block + after

sys.stdout.write(text)
PY
    then
      if [[ ! -f "$target" ]] || ! cmp -s -- "$tmp" "$target"; then
        install_generated_file "$tmp" "$settings" 0644
        rm -f -- "$tmp"
        log "vscode: set theme to $active_theme"
        changed=1
      else
        rm -f -- "$tmp"
      fi
    else
      rm -f -- "$tmp"
      warn "failed to update VS Code settings: $settings"
    fi
