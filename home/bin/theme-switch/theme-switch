apply_chrome_live_theme() {
  local mode="$1"

  [[ "${THEME_SWITCH_CHROME_LIVE:-1}" != "0" ]] || return 0
  command -v python3 &>/dev/null || return 0

  python3 - "$mode" "$CHROME_CDP_URL" "$CHROME_CDP_PORT" <<'PY'
import base64
import json
import os
import errno
import socket
import struct
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request

mode = sys.argv[1]
cdp_url = sys.argv[2].rstrip("/")
port = sys.argv[3]
warned_prefix = "theme-switch: "


def warn(message):
    print(warned_prefix + message, file=sys.stderr)


def chrome_is_running():
    try:
        result = subprocess.run(
            ["pgrep", "-x", "chrome"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        return result.returncode == 0
    except FileNotFoundError:
        return False


def request_json(url, *, method="GET", timeout=1.5):
    request = urllib.request.Request(url, method=method)
    with urllib.request.urlopen(request, timeout=timeout) as response:
        return json.loads(response.read().decode("utf-8"))


def get_version():
    try:
        return request_json(f"{cdp_url}/json/version")
    except urllib.error.URLError as exc:
        reason = getattr(exc, "reason", None)
        refused = isinstance(reason, ConnectionRefusedError) or getattr(reason, "errno", None) == errno.ECONNREFUSED
        timed_out = isinstance(reason, TimeoutError) or getattr(reason, "errno", None) == errno.ETIMEDOUT
        if chrome_is_running() and (refused or timed_out):
            warn(
                "Chrome is running without the managed DevTools endpoint; "
                "restart Chrome once through google-chrome-live so live theme switching can repaint it."
            )
        elif not refused:
            warn(
                f"Chrome DevTools endpoint is unavailable at {cdp_url}; "
                f"if port {port} is occupied, set THEME_SWITCH_CHROME_CDP_PORT or THEME_SWITCH_CHROME_CDP_URL."
            )
        return None
    except Exception:
        warn(
            f"Chrome DevTools endpoint at {cdp_url} did not return Chrome JSON; "
            f"if port {port} is occupied, set THEME_SWITCH_CHROME_CDP_PORT or THEME_SWITCH_CHROME_CDP_URL."
        )
        return None


def create_target():
    encoded_url = urllib.parse.quote("chrome://new-tab-page", safe=":/")
    try:
        return request_json(f"{cdp_url}/json/new?{encoded_url}", method="PUT")
    except urllib.error.HTTPError:
        return request_json(f"{cdp_url}/json/new?{encoded_url}")


def close_target(target_id):
    if not target_id:
        return
    try:
        urllib.request.urlopen(f"{cdp_url}/json/close/{target_id}", timeout=1).close()
    except Exception:
        pass


class CDPWebSocket:
    def __init__(self, websocket_url):
        parsed = urllib.parse.urlparse(websocket_url)
        if parsed.scheme != "ws":
            raise ValueError(f"unsupported websocket URL: {websocket_url}")
        self.host = parsed.hostname or "127.0.0.1"
        self.port = parsed.port or 80
        self.path = parsed.path or "/"
        if parsed.query:
            self.path += "?" + parsed.query
        self.sock = socket.create_connection((self.host, self.port), timeout=2)
        key = base64.b64encode(os.urandom(16)).decode("ascii")
        headers = (
            f"GET {self.path} HTTP/1.1\r\n"
            f"Host: {self.host}:{self.port}\r\n"
            "Upgrade: websocket\r\n"
            "Connection: Upgrade\r\n"
            f"Sec-WebSocket-Key: {key}\r\n"
            "Sec-WebSocket-Version: 13\r\n"
            "\r\n"
        )
        self.sock.sendall(headers.encode("ascii"))
        response = self.sock.recv(4096)
        if b" 101 " not in response.split(b"\r\n", 1)[0]:
            raise RuntimeError("websocket handshake failed")
        self.next_id = 1

    def close(self):
        try:
            self.sock.close()
        except Exception:
            pass

    def send_frame(self, payload):
        data = payload.encode("utf-8")
        header = bytearray([0x81])
        if len(data) < 126:
            header.append(0x80 | len(data))
        elif len(data) < 65536:
            header.append(0x80 | 126)
            header.extend(struct.pack("!H", len(data)))
        else:
            header.append(0x80 | 127)
            header.extend(struct.pack("!Q", len(data)))
        mask = os.urandom(4)
        header.extend(mask)
        masked = bytes(byte ^ mask[index % 4] for index, byte in enumerate(data))
        self.sock.sendall(bytes(header) + masked)

    def recv_exact(self, size):
        chunks = []
        remaining = size
        while remaining:
            chunk = self.sock.recv(remaining)
            if not chunk:
                raise RuntimeError("websocket closed")
            chunks.append(chunk)
            remaining -= len(chunk)
        return b"".join(chunks)

    def recv_frame(self):
        first, second = self.recv_exact(2)
        opcode = first & 0x0F
        masked = bool(second & 0x80)
        length = second & 0x7F
        if length == 126:
            length = struct.unpack("!H", self.recv_exact(2))[0]
        elif length == 127:
            length = struct.unpack("!Q", self.recv_exact(8))[0]
        mask = self.recv_exact(4) if masked else b""
        payload = self.recv_exact(length) if length else b""
        if masked:
            payload = bytes(byte ^ mask[index % 4] for index, byte in enumerate(payload))
        if opcode == 8:
            raise RuntimeError("websocket closed")
        if opcode == 9:
            return self.recv_frame()
        if opcode != 1:
            return self.recv_frame()
        return payload.decode("utf-8")

    def call(self, method, params):
        message_id = self.next_id
        self.next_id += 1
        self.send_frame(json.dumps({"id": message_id, "method": method, "params": params}))
        deadline = time.monotonic() + 5
        while time.monotonic() < deadline:
            response = json.loads(self.recv_frame())
            if response.get("id") == message_id:
                if "error" in response:
                    raise RuntimeError(response["error"])
                return response.get("result", {})
        raise TimeoutError(method)


def apply_live(websocket_url):
    expression = f"""
(async () => {{
  const browserProxyModule = await import('chrome://resources/cr_components/customize_color_scheme_mode/browser_proxy.js');
  const mojom = await import('chrome://resources/cr_components/customize_color_scheme_mode/customize_color_scheme_mode.mojom-webui.js');
  const proxy = browserProxyModule.CustomizeColorSchemeModeBrowserProxy.getInstance();
  const colorSchemeMode = {mode!r} === 'dark' ? mojom.ColorSchemeMode.kDark : mojom.ColorSchemeMode.kLight;
  await proxy.handler.setColorSchemeMode(colorSchemeMode);
  return {mode!r};
}})()
"""
    ws = CDPWebSocket(websocket_url)
    try:
        result = ws.call(
            "Runtime.evaluate",
            {
                "expression": expression,
                "awaitPromise": True,
                "returnByValue": True,
                "userGesture": True,
            },
        )
    finally:
        ws.close()
    exception = result.get("exceptionDetails")
    if exception:
        raise RuntimeError(exception.get("text", "Runtime.evaluate failed"))


version = get_version()
if not version:
    raise SystemExit(0)

target = None
try:
    target = create_target()
    websocket_url = target.get("webSocketDebuggerUrl")
    if not websocket_url:
        raise RuntimeError("missing page websocket URL")
    apply_live(websocket_url)
    print(f"chrome: applied live {mode} theme")
except Exception as exc:
    warn(
        f"Chrome live theme switch failed via {cdp_url}: {exc}. "
        f"Restart Chrome through google-chrome-live, or set THEME_SWITCH_CHROME_LIVE=0 to disable this path."
    )
finally:
    if target:
        close_target(target.get("id"))
PY
}

apply_spicetify_if_configured() {
  local mode="$1"
  local theme="${THEME_SWITCH_SPICETIFY_THEME:-}"
  local dark_scheme="${THEME_SWITCH_SPICETIFY_DARK:-Dark}"
  local light_scheme="${THEME_SWITCH_SPICETIFY_LIGHT:-Light}"
  local scheme

  [[ -n "$theme" ]] || return 0
  command -v spicetify &>/dev/null || return 0

  if [[ "$mode" == "dark" ]]; then
    scheme="$dark_scheme"
  else
    scheme="$light_scheme"
  fi

  run_optional spicetify config current_theme "$theme" color_scheme "$scheme"
  run_optional spicetify apply
}

run_theme_adapters() {
  local mode="$1"
  local adapters="$2"

  [[ -n "$adapters" ]] || return 0
  log "theme adapters: $adapters"

  if adapter_in_list "$adapters" vscode; then
    update_vscode_theme "$mode"
  fi
  if adapter_in_list "$adapters" chromium; then
    update_chromium_theme "$mode"
  fi
  if adapter_in_list "$adapters" chrome-live; then
    apply_chrome_live_theme "$mode"
  fi
  if adapter_in_list "$adapters" zsh; then
    update_zsh_theme "$mode"
  fi
  if adapter_in_list "$adapters" codex; then
    update_codex_theme "$mode"
  fi
  if adapter_in_list "$adapters" spicetify; then
    apply_spicetify_if_configured "$mode"
  fi
}

apply_mode() {
  local mode="$1"
  local adapters
  ensure_mode "$mode"
  adapters="$(all_supported_adapters)"

  mkdir -p -- "$STATE_DIR" "$CURRENT_DIR"
  prepare_config_theme_links "$mode"

  link_current "$mode" waybar.css waybar.css
  link_current "$mode" nwg-bar.css nwg-bar.css
  link_current "$mode" kitty.conf kitty.conf
  link_current "$mode" rofi.rasi rofi.rasi
  link_current "$mode" dunst.conf dunst.conf
  link_current "$mode" search.svg search.svg

  printf '%s\n' "$mode" > "$CURRENT_FILE"

  apply_xdg_gtk "$mode"
  run_theme_adapters "$mode" "$adapters"

  reload_waybar
  reload_kitty
  reload_dunst

  log "theme: $mode"
}

current_mode() {
  if [[ -f "$CURRENT_FILE" ]]; then
    cat "$CURRENT_FILE"
  else
    printf 'dark\n'
  fi
}

main() {
  local command="${1:-help}"
  local mode

  case "$command" in
    apply)
      shift
      [[ $# -eq 1 ]] || die "apply requires exactly one mode"
      apply_mode "$1"
      ;;
    prepare)
      [[ $# -le 2 ]] || die "prepare accepts at most one mode"
      prepare_config_theme_links "${2:-dark}"
      ;;
    current)
      current_mode
      ;;
    toggle)
      shift
      [[ $# -eq 0 ]] || die "toggle does not accept arguments"
      case "$(current_mode)" in
        dark) mode=light ;;
        light) mode=dark ;;
        *) mode=dark ;;
      esac
      apply_mode "$mode"
      ;;
    help|--help|-h)
      usage
      ;;
    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
